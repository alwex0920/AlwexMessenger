{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://alwexmessenger.alwex.workers.dev/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    },
    { "src": "/sw.js", "dest": "/sw.js", "headers": { "Content-Type": "application/javascript" } }
  ]
}
