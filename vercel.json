{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    { "src": "site.webmanifest", "use": "@vercel/static" },
    {
      "src": "*.ico",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "*.svg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://alwexmessenger.alwex.workers.dev/api/$1"
    },
    {
      "src": "/sw.js",
      "dest": "https://alwexmessenger.alwex.workers.dev/sw.js"
    },
    {
      "src": "/site.webmanifest",
      "dest": "https://alwexmessenger.alwex.workers.dev/site.webmanifest"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)\\.(ico|png|jpg|jpeg|svg|webmanifest)",
      "dest": "/$1.$2"
    }
  ]
}
